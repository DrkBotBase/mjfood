function actualizarPaginacion(paginacion) {
    const infoPaginacion = document.getElementById('info-paginacion');
    const paginaActualEl = document.getElementById('pagina-actual');
    const btnAnterior = document.getElementById('btn-anterior');
    const btnSiguiente = document.getElementById('btn-siguiente');
    
    if (infoPaginacion) {
        const inicio = paginacion.total > 0 ? ((paginaActual - 1) * limitePorPagina) + 1 : 0;
        const fin = Math.min(paginaActual * limitePorPagina, paginacion.total);
        infoPaginacion.textContent = `Mostrando ${inicio} - ${fin} de ${paginacion.total} pedidos`;
    }
    
    if (paginaActualEl) paginaActualEl.textContent = paginaActual;
    if (btnAnterior) btnAnterior.disabled = paginaActual === 1;
    if (btnSiguiente) btnSiguiente.disabled = paginaActual >= paginacion.paginas;
}

        function verDetallesPedidoPorIndice(index) {
            const pedido = todosLosPedidos[index];
            if (pedido) verDetallesPedido(pedido);
        }


        function cambiarPagina(direccion) {
            if (direccion === 'siguiente' && paginaActual < Math.ceil(totalPedidos / limitePorPagina)) {
                paginaActual++;
                cargarHistorialPedidos();
            } else if (direccion === 'anterior' && paginaActual > 1) {
                paginaActual--;
                cargarHistorialPedidos();
            }
        }

