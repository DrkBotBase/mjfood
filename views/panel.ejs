            const boton = event.target;
            const originalText = boton.innerHTML;
            
            boton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Actualizando...';
            boton.disabled = true;
            
            cargarDatosIniciales().finally(() => {
                boton.innerHTML = originalText;
                boton.disabled = false;
            });
        }
        
        function mostrarMensaje(mensaje, tipo = 'info') {
            const notificacion = document.createElement('div');
            notificacion.className = `fixed top-4 right-4 px-6 py-3 rounded-lg shadow-lg text-white font-semibold z-50 transition-transform transform translate-x-0 ${
                tipo === 'error' ? 'bg-red-500' : 
                tipo === 'success' ? 'bg-green-500' : 'bg-blue-500'
            }`;
            notificacion.textContent = mensaje;
            notificacion.style.transform = 'translateX(100%)';
            
            document.body.appendChild(notificacion);
            
            setTimeout(() => {
                notificacion.style.transform = 'translateX(0)';
            }, 10);
            
            setTimeout(() => {
                notificacion.style.transform = 'translateX(100%)';
                setTimeout(() => {
                    notificacion.remove();
                }, 300);
            }, 3000);
        }
        
        function mostrarError(mensaje) {
            console.error(mensaje);
            mostrarMensaje(mensaje, 'error');
        }
        
        document.getElementById('form-cambiar-token').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const passwordActual = document.getElementById('token-actual').value;
            const passwordNuevo = document.getElementById('token-nuevo').value;
            const passwordConfirmar = document.getElementById('token-confirmar').value;

            if (passwordNuevo !== passwordConfirmar) {
                mostrarError('Las nuevas contraseñas no coinciden.');
                return;
            }

            mostrarLoading(true);
            try {
                const response = await fetch('/admin/change-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        passwordActual,
                        passwordNuevo
                    })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    mostrarMensaje('Contraseña actualizada correctamente.', 'success');
                    document.getElementById('form-cambiar-token').reset();
                } else {
                    throw new Error(data.error || 'No se pudo cambiar la contraseña.');
                }
            } catch (error) {
                mostrarError(error.message);
            } finally {
                mostrarLoading(false);
            }
        });

        // --- FUNCIONES DE GESTIÓN DE MENÚ ---
        function cambiarCategoriaTab(catId) {
            document.querySelectorAll('.cat-tab').forEach(el => {
                el.classList.remove('border-blue-500', 'text-blue-600');
                el.classList.add('border-transparent', 'text-gray-500');
            });
            document.querySelectorAll('.cat-content').forEach(el => {
                el.classList.add('hidden');
                el.classList.remove('block');
            });
            const tab = document.getElementById('tab-cat-' + catId);
            const content = document.getElementById('content-cat-' + catId);
            if (tab) {
                tab.classList.add('border-blue-500', 'text-blue-600');
                tab.classList.remove('border-transparent', 'text-gray-500');
            }
            if (content) {
                content.classList.remove('hidden');
                content.classList.add('block');
            }
        }

        function openAddCategoryModal() {
            document.getElementById('input-categoria').value = '';
            document.getElementById('modal-categoria').classList.remove('hidden');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
        }

        async function saveCategory() {
            const category = document.getElementById('input-categoria').value.trim();
            if (!category) return alert('Por favor, ingresa un nombre para la categoría');

            try {
                const response = await fetch('/menu/category', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ category })
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Error al crear la categoría');
                }
            } catch (error) {
                console.error(error);
                alert('Error de red');
            }
        }

        async function deleteCategory(categoryId) {
            if (!confirm('¿Estás seguro de que deseas eliminar esta categoría y todos sus productos?')) return;

            try {
                const response = await fetch(`/menu/category/${categoryId}`, {
                    method: 'DELETE'
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Error al eliminar la categoría');
                }
            } catch (error) {
                console.error(error);
                alert('Error de red');
            }
        }

        function openAddItemModal(categoryId) {
            document.getElementById('modal-item-title').innerText = 'Nuevo Producto';
            document.getElementById('item-categoryId').value = categoryId;
            document.getElementById('item-id').value = '';
            document.getElementById('item-name').value = '';
            document.getElementById('item-description').value = '';
            document.getElementById('item-basePrice').value = '';
            document.getElementById('item-image').value = '';
            document.getElementById('modal-item').classList.remove('hidden');
        }

        function editItem(categoryId, item) {
            document.getElementById('modal-item-title').innerText = 'Editar Producto';
            document.getElementById('item-categoryId').value = categoryId;
            document.getElementById('item-id').value = item.id;
            document.getElementById('item-name').value = item.name;
            document.getElementById('item-description').value = item.description || '';
            document.getElementById('item-basePrice').value = item.basePrice;
            document.getElementById('item-image').value = item.image || '';
            document.getElementById('modal-item').classList.remove('hidden');
        }

        async function saveItem() {
            const categoryId = document.getElementById('item-categoryId').value;
            const id = document.getElementById('item-id').value;
            const item = {
                name: document.getElementById('item-name').value.trim(),
                description: document.getElementById('item-description').value.trim(),
                basePrice: parseInt(document.getElementById('item-basePrice').value),
                image: document.getElementById('item-image').value.trim()
            };

            if (!item.name || isNaN(item.basePrice)) {
                return alert('Nombre y Precio Base son obligatorios y el precio debe ser un número.');
            }

            try {
                const isEdit = id !== '';
                const url = '/menu/item';
                const method = isEdit ? 'PUT' : 'POST';
                const body = isEdit ? { categoryId, itemId: id, item } : { categoryId, item };

                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await response.json();

                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Error al guardar el producto');
                }
            } catch (error) {
                console.error(error);
                alert('Error de red');
            }
        }

        async function deleteItem(categoryId, itemId) {
            if (!confirm('¿Estás seguro de que deseas eliminar este producto?')) return;

            try {
                const response = await fetch(`/menu/item/${categoryId}/${itemId}`, {
                    method: 'DELETE'
                });
                const data = await response.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Error al eliminar el producto');
                }
            } catch (error) {
                console.error(error);
                alert('Error de red');
            }
        }

        // --- VARIANTES ---
        let currentVariants = [];

        function openVariantsModal(categoryId, itemId, variants) {
            document.getElementById('variant-categoryId').value = categoryId;
            document.getElementById('variant-itemId').value = itemId;
            currentVariants = JSON.parse(JSON.stringify(variants)); // deep copy
            renderVariants();
            document.getElementById('modal-variants').classList.remove('hidden');
        }

        function renderVariants() {
            const container = document.getElementById('variants-container');
            container.innerHTML = '';

            if (currentVariants.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-8 text-gray-500 bg-gray-50 rounded-lg border border-gray-200">
                        No hay variantes configuradas.
                    </div>
                `;
                return;
            }

            currentVariants.forEach((group, groupIndex) => {
                const groupHtml = `
                    <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4 relative shadow-sm">
                        <button onclick="removeVariantGroup(${groupIndex})" class="absolute top-4 right-4 text-red-400 hover:text-red-600 p-1 bg-white rounded-full shadow-sm">
                            <i class="fas fa-trash-alt"></i>
                        </button>

                        <div class="grid grid-cols-2 gap-4 mb-4 pr-8">
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1">Nombre del Grupo</label>
                                <input type="text" value="${group.name || ''}" onchange="updateGroupField(${groupIndex}, 'name', this.value)" placeholder="Ej: Tamaño, Extras" class="w-full border-gray-300 rounded-md shadow-sm text-sm focus:ring-blue-500 focus:border-blue-500 py-2 px-3">
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1">Tipo de Selección</label>
                                <select onchange="updateGroupField(${groupIndex}, 'type', this.value)" class="w-full border-gray-300 rounded-md shadow-sm text-sm focus:ring-blue-500 focus:border-blue-500 py-2 px-3">
                                    <option value="radio" ${group.type === 'radio' ? 'selected' : ''}>Selección Única (Radio)</option>
                                    <option value="checkbox" ${group.type === 'checkbox' ? 'selected' : ''}>Selección Múltiple (Checkbox)</option>
                                </select>
                            </div>
                        </div>

                        <div class="bg-white rounded border border-gray-200 p-3">
                            <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wider mb-2">Opciones</label>

                            <div class="space-y-2 mb-3">
                                ${(group.options || []).map((opt, optIndex) => `
                                    <div class="flex items-center space-x-2 bg-gray-50 p-2 rounded border border-gray-100 group">
                                        <div class="flex-grow flex space-x-2">
                                            <input type="text" value="${opt.label || ''}" onchange="updateOptionField(${groupIndex}, ${optIndex}, 'label', this.value)" placeholder="Nombre (ej: Grande)" class="w-1/2 border-gray-300 rounded-md shadow-sm text-sm py-1.5 px-2">
                                            <div class="relative w-1/2">
                                                <div class="absolute inset-y-0 left-0 pl-2 flex items-center pointer-events-none">
                                                    <span class="text-gray-500 sm:text-sm">$</span>
                                                </div>
                                                <input type="number" value="${opt.price || 0}" onchange="updateOptionField(${groupIndex}, ${optIndex}, 'price', this.value)" placeholder="Precio extra" class="w-full pl-6 border-gray-300 rounded-md shadow-sm text-sm py-1.5 pr-2">
                                            </div>
                                        </div>
                                        <button onclick="removeOption(${groupIndex}, ${optIndex})" class="text-gray-400 hover:text-red-500 px-2 py-1 opacity-50 group-hover:opacity-100 transition">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                `).join('')}
                            </div>

                            <button onclick="addOption(${groupIndex})" class="text-xs text-blue-600 font-medium hover:text-blue-800 flex items-center bg-blue-50 px-3 py-1.5 rounded-md transition">
                                <i class="fas fa-plus mr-1"></i> Añadir Opción
                            </button>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', groupHtml);
            });
        }

        function addVariantGroup() {
            currentVariants.push({
                name: '',
                type: 'radio',
                options: [{ label: '', price: 0 }]
            });
            renderVariants();
        }

        function removeVariantGroup(index) {
            currentVariants.splice(index, 1);
            renderVariants();
        }

        function updateGroupField(index, field, value) {
            currentVariants[index][field] = value;
        }

        function addOption(groupIndex) {
            if (!currentVariants[groupIndex].options) {
                currentVariants[groupIndex].options = [];
            }
            currentVariants[groupIndex].options.push({ label: '', price: 0 });
            renderVariants();
        }

        function removeOption(groupIndex, optIndex) {
            currentVariants[groupIndex].options.splice(optIndex, 1);
            renderVariants();
        }

        function updateOptionField(groupIndex, optIndex, field, value) {
            if (field === 'price') {
                value = parseInt(value) || 0;
            }
            currentVariants[groupIndex].options[optIndex][field] = value;
        }

        async function saveVariants() {
            const categoryId = document.getElementById('variant-categoryId').value;
            const itemId = document.getElementById('variant-itemId').value;

            // Clean up empty variants
            const cleanedVariants = currentVariants.filter(group => group.name.trim() !== '').map(group => {
                return {
                    name: group.name,
                    type: group.type,
                    options: (group.options || []).filter(opt => opt.label.trim() !== '')
                };
            });

            try {
                const response = await fetch('/menu/item/variants', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ categoryId, itemId, variants: cleanedVariants })
                });
                const data = await response.json();

                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Error al guardar variantes');
                }
            } catch (error) {
                console.error(error);
                alert('Error de red');
            }
        }
    </script>
</body>
</html>