                            class="bg-blue-500 text-white px-3 py-1 rounded-lg hover:bg-blue-600 text-sm">
                        <i class="fas fa-eye mr-1"></i> Ver
                    </button>
                </td>
            </tr>
        `;
        tbody.innerHTML += row;
    });
