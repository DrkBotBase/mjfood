<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Restaurante - Panel Admin</title>
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .error-message {
      color: #dc2626;
      font-size: 0.875rem;
      margin-top: 0.25rem;
      display: none;
    }
    .input-error {
      border-color: #dc2626 !important;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <header class="bg-white shadow-lg">
    <div class="container mx-auto px-4 py-4">
      <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Panel Admin - Registro</h1>
        <a href="/admin/panel" class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition">
          Volver al Panel
        </a>
      </div>
    </div>
  </header>

  <main class="container mx-auto px-4 py-10 max-w-md">
    <div class="bg-white rounded-xl shadow-lg p-8">
      <h2 class="text-2xl font-bold text-center text-gray-800 mb-6">Registrar Nuevo Restaurante</h2>

      <% if (error) {
        %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
          <%= error %>
        </div>
        <%
      } %>

      <% if (typeof success !== 'undefined' && success) {
        %>
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4">
          <%= success %>
        </div>
        <%
      } %>

      <form action="/admin/register" method="POST" class="space-y-4">
        <div>
          <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Usuario (Login)</label>
          <input type="text" id="username" name="username" required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
          <input type="password" id="password" name="password" required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500">
        </div>

        <div>
          <label for="restauranteId" class="block text-sm font-medium text-gray-700 mb-1">ID Restaurante (Slug)</label>
          <input type="text" id="restauranteId" name="restauranteId" required
          placeholder="ej: mi-restaurante"
          pattern="[a-z0-9-_]+"
          title="Solo letras minúsculas, números, guiones (-) y guiones bajos (_) - sin espacios, comas ni otros caracteres especiales"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500"
          oninput="validateRestauranteId(this)">
          <p class="text-xs text-gray-500 mt-1">
            Este será el identificador en la URL (ej: misitio.com/mi-restaurante)
          </p>
          <div id="restauranteIdError" class="error-message">
            Solo se permiten letras minúsculas, números, guiones (-) y guiones bajos (_)
          </div>
        </div>

        <button type="submit"
          class="w-full bg-green-500 text-white font-bold py-3 px-4 rounded-lg hover:bg-green-600 transition duration-200 mt-6">
          <i class="fas fa-plus-circle mr-2"></i> Registrar Restaurante
        </button>
      </form>
    </div>
  </main>

  <script>
    function validateRestauranteId(input) {
      const errorDiv = document.getElementById('restauranteIdError');
      const originalValue = input.value;

      let cleanedValue = originalValue.toLowerCase().replace(/\s+/g, '-');
      const validPattern = /^[a-z0-9-_]*$/;

      if (cleanedValue !== originalValue) {
        input.value = cleanedValue;
      }

      if (cleanedValue && !validPattern.test(cleanedValue)) {
        input.classList.add('input-error');
        errorDiv.style.display = 'block';
      } else {
        input.classList.remove('input-error');
        errorDiv.style.display = 'none';
      }
    }

    document.querySelector('form').addEventListener('submit', function(e) {
      const restauranteId = document.getElementById('restauranteId');
      const validPattern = /^[a-z0-9-_]+$/;

      if (!validPattern.test(restauranteId.value)) {
        e.preventDefault();
        restauranteId.classList.add('input-error');
        document.getElementById('restauranteIdError').style.display = 'block';

        restauranteId.scrollIntoView({
          behavior: 'smooth', block: 'center'
        });
      }
    });

    document.addEventListener('DOMContentLoaded', function() {
      const restauranteId = document.getElementById('restauranteId');
      if (restauranteId.value) {
        validateRestauranteId(restauranteId);
      }
    });
  </script>
</body>
</html>