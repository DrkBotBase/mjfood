<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Gestión de Menú - <%= restaurante %></title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .touch-target { min-height: 44px; min-width: 44px; }
        .sidebar-link { display: flex; align-items: center; padding: 0.875rem 1.25rem; border-radius: 0.5rem; transition: all 0.2s ease; margin-bottom: 0.5rem; font-weight: 500; color: #475569; }
        .sidebar-link:hover { background-color: #f1f5f9; color: #0f172a; }
        .sidebar-link.active { background-color: #e0e7ff; color: #4338ca; }

        .tab-btn { white-space: nowrap; padding: 0.75rem 1.5rem; border-bottom: 2px solid transparent; font-weight: 600; color: #64748b; transition: all 0.2s ease; cursor: pointer; }
        .tab-btn:hover { color: #0f172a; }
        .tab-btn.active { color: #4338ca; border-bottom-color: #4338ca; }

        .fab { position: fixed; bottom: 2rem; right: 2rem; width: 60px; height: 60px; border-radius: 50%; background-color: #4338ca; color: white; display: flex; justify-content: center; align-items: center; font-size: 1.5rem; box-shadow: 0 10px 25px -5px rgba(67, 56, 202, 0.5); z-index: 40; transition: transform 0.2s, background-color 0.2s; }
        .fab:hover { background-color: #3730a3; transform: scale(1.05); }
        .fab:active { transform: scale(0.95); }

        /* Ocultar barra scroll en tabs movil */
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .action-btn { transition: all 0.1s ease; }
        .action-btn:active { transform: scale(0.9); }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex text-slate-800 antialiased overflow-hidden">

    <!-- Overlay movil -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="fixed inset-y-0 left-0 w-64 bg-white border-r border-slate-200 z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300 flex flex-col">
        <div class="h-16 flex shrink-0 items-center justify-between px-6 border-b border-slate-100">
            <span class="text-xl font-bold text-indigo-600 flex items-center">
                <i class="fas fa-utensils mr-2"></i> MJFOOD
            </span>
            <button onclick="toggleSidebar()" class="md:hidden text-slate-500 hover:text-slate-800 touch-target flex items-center justify-center">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <div class="p-4 flex-1 overflow-y-auto">
            <nav>
                <a href="/admin/panel" class="sidebar-link">
                    <i class="fas fa-home w-6 text-center"></i> Inicio
                </a>
                <a href="/admin/panel#pendientes" class="sidebar-link">
                    <i class="fas fa-receipt w-6 text-center"></i> Pedidos
                </a>
                <a href="/menu/gestion" class="sidebar-link active">
                    <i class="fas fa-book-open w-6 text-center"></i> Mi Menú
                </a>
                <a href="/admin/panel#seguridad" class="sidebar-link">
                    <i class="fas fa-cog w-6 text-center"></i> Configuración
                </a>
            </nav>
        </div>
        <div class="p-4 border-t border-slate-100">
            <a href="/admin/logout" class="sidebar-link text-rose-600 hover:bg-rose-50 hover:text-rose-700 m-0">
                <i class="fas fa-sign-out-alt w-6 text-center"></i> Cerrar Sesión
            </a>
        </div>
    </aside>

    <!-- Content -->
    <main class="flex-1 flex flex-col h-screen md:ml-64 w-full md:w-[calc(100%-16rem)] transition-all duration-300">

        <!-- Mobile Header -->
        <header class="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-4 md:hidden shrink-0">
            <div class="flex items-center">
                <button onclick="toggleSidebar()" class="touch-target text-slate-600 hover:text-slate-900 focus:outline-none flex items-center justify-center mr-2">
                    <i class="fas fa-bars text-xl"></i>
                </button>
                <span class="font-bold text-lg text-slate-800 truncate"><%= menuData.config.nombre || restaurante %></span>
            </div>
        </header>

        <!-- Header Content -->
        <div class="bg-white px-4 sm:px-8 py-6 border-b border-slate-200 shrink-0">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 hidden md:block">Gestión de Menú</h1>
                    <p class="text-sm text-slate-500 mt-1">Organiza tus productos y categorías fácilmente.</p>
                </div>
                <button onclick="addCategoryPrompt()" class="bg-indigo-50 text-indigo-700 hover:bg-indigo-100 px-4 py-2.5 rounded-lg text-sm font-semibold transition flex items-center">
                    <i class="fas fa-folder-plus mr-2"></i> Añadir Categoría
                </button>
            </div>
        </div>

        <!-- Categories Tabs -->
        <div class="bg-white border-b border-slate-200 px-4 sm:px-8 overflow-x-auto hide-scrollbar flex gap-2 pt-2 shrink-0" id="categoryTabs">
            <% if(menuData && menuData.menu && menuData.menu.length > 0) { %>
                <% menuData.menu.forEach((cat, index) => { %>
                    <div class="tab-btn <%= index === 0 ? 'active' : '' %>" onclick="selectCategory('<%= cat._id %>', this)">
                        <%= cat.category %>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="py-3 text-slate-400 text-sm">No hay categorías. Crea una para comenzar.</div>
            <% } %>
        </div>

        <!-- Main scrollable area for products -->
        <div class="flex-1 overflow-y-auto p-4 sm:p-8 relative">
            <div id="categoriesContainer" class="max-w-4xl mx-auto pb-24">
                <% if(menuData && menuData.menu && menuData.menu.length > 0) { %>
                    <% menuData.menu.forEach((cat, index) => { %>
                        <div id="cat-content-<%= cat._id %>" class="category-content <%= index === 0 ? 'block' : 'hidden' %> animate-fade-in">

                            <div class="flex justify-between items-end mb-4">
                                <h2 class="text-xl font-bold text-slate-800"><%= cat.category %></h2>
                                <button onclick="deleteCategory('<%= cat._id %>')" class="text-sm text-rose-500 hover:text-rose-700 transition flex items-center">
                                    <i class="fas fa-trash-alt mr-1"></i> Eliminar categoría
                                </button>
                            </div>

                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
                                <% if (cat.items && cat.items.length > 0) { %>
                                    <% cat.items.forEach((item) => { %>
                                        <div class="p-4 flex items-center gap-4 hover:bg-slate-50 transition">

                                            <!-- Imagen -->
                                            <div class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 rounded-lg overflow-hidden border border-slate-100 bg-slate-50 flex items-center justify-center">
                                                <% if(item.image) { %>
                                                    <img src="<%= item.image %>" class="w-full h-full object-cover">
                                                <% } else { %>
                                                    <i class="fas fa-image text-slate-300 text-2xl"></i>
                                                <% } %>
                                            </div>

                                            <!-- Datos (Centro) -->
                                            <div class="flex-1 min-w-0">
                                                <h3 class="font-bold text-slate-800 text-base sm:text-lg truncate"><%= item.name %></h3>
                                                <p class="text-xs sm:text-sm text-slate-500 truncate mt-0.5"><%= item.description || 'Sin descripción' %></p>
                                                <div class="flex items-center gap-3 mt-1.5">
                                                    <span class="font-semibold text-emerald-600">$<%= item.basePrice.toLocaleString('es-CO') %></span>
                                                    <% if (item.variants && item.variants.length > 0) { %>
                                                        <span class="bg-indigo-50 text-indigo-700 text-[10px] sm:text-xs px-2 py-0.5 rounded-full font-medium">
                                                            <%= item.variants.length %> variantes
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </div>

                                            <!-- Botones Acción (Derecha) -->
                                            <div class="flex items-center gap-1 sm:gap-2 shrink-0">
                                                <button onclick="openVariantsModal('<%= cat._id %>', '<%= item.id %>', '<%= item.name.replace(/'/g, "\\'") %>', '<%= encodeURIComponent(JSON.stringify(item.variants || [])) %>')"
                                                        class="action-btn touch-target w-10 h-10 sm:w-11 sm:h-11 rounded-full flex items-center justify-center text-indigo-600 hover:bg-indigo-50 transition tooltip" title="Variantes">
                                                    <i class="fas fa-sliders-h text-lg"></i>
                                                </button>
                                                <button onclick="openEditItemModal('<%= cat._id %>', '<%= item.id %>', '<%= item.name.replace(/'/g, "\\'") %>', '<%= (item.description || '').replace(/'/g, "\\'") %>', <%= item.basePrice %>, '<%= item.image || '' %>')"
                                                        class="action-btn touch-target w-10 h-10 sm:w-11 sm:h-11 rounded-full flex items-center justify-center text-slate-600 hover:bg-slate-100 transition tooltip" title="Editar">
                                                    <i class="fas fa-pen text-lg"></i>
                                                </button>
                                                <button onclick="deleteItem('<%= cat._id %>', '<%= item.id %>')"
                                                        class="action-btn touch-target w-10 h-10 sm:w-11 sm:h-11 rounded-full flex items-center justify-center text-rose-500 hover:bg-rose-50 transition tooltip" title="Eliminar">
                                                    <i class="fas fa-trash-alt text-lg"></i>
                                                </button>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="p-8 text-center text-slate-400">
                                        <i class="fas fa-box-open text-3xl mb-2 opacity-50"></i>
                                        <p class="text-sm">Esta categoría no tiene productos.</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="flex flex-col items-center justify-center py-20 text-center px-4">
                        <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-4">
                            <i class="fas fa-folder-open text-slate-400 text-3xl"></i>
                        </div>
                        <h2 class="text-xl font-bold text-slate-700 mb-2">Tu menú está vacío</h2>
                        <p class="text-slate-500 max-w-sm mb-6">Comienza creando una categoría usando el botón "Añadir Categoría" en la parte superior.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- FAB Add Item -->
        <button id="fabAddItem" onclick="openAddItemModalForCurrentTab()" class="fab hidden" title="Añadir Producto">
            <i class="fas fa-plus"></i>
        </button>
    </main>

    <!-- Modals -->
    <!-- Modal Producto -->
    <div id="addItemModal" class="fixed inset-0 bg-slate-900/40 hidden items-center justify-center z-[60] p-4 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md my-auto transform transition-all flex flex-col">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
                <h3 class="text-xl font-bold text-slate-800" id="modalTitle">Añadir Producto</h3>
                <button onclick="closeAddItemModal()" class="text-slate-400 hover:text-slate-600 bg-slate-50 hover:bg-slate-100 w-8 h-8 rounded-full flex items-center justify-center transition">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <input type="hidden" id="modalCategoryId">
                <input type="hidden" id="modalItemId">
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Nombre <span class="text-rose-500">*</span></label>
                    <input type="text" id="itemName" placeholder="Ej: Hamburguesa Clásica" class="w-full bg-slate-50 border border-slate-200 px-4 py-2.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Descripción</label>
                    <textarea id="itemDesc" placeholder="Ingredientes y detalles..." rows="2" class="w-full bg-slate-50 border border-slate-200 px-4 py-2.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Precio Base ($) <span class="text-rose-500">*</span></label>
                    <input type="number" id="itemPrice" placeholder="0" min="0" class="w-full bg-slate-50 border border-slate-200 px-4 py-2.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">URL de Imagen</label>
                    <input type="url" id="itemImage" placeholder="https://..." class="w-full bg-slate-50 border border-slate-200 px-4 py-2.5 rounded-xl focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition text-sm">
                </div>
            </div>
            <div class="px-6 py-4 bg-slate-50 rounded-b-2xl flex justify-end gap-3 border-t border-slate-100">
                <button onclick="closeAddItemModal()" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl text-slate-700 hover:bg-slate-50 font-medium transition active:scale-95">Cancelar</button>
                <button onclick="submitItem()" id="btnSubmitItem" class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 font-medium shadow-sm shadow-indigo-200 transition active:scale-95 flex items-center">
                    Guardar Producto
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Variantes -->
    <div id="variantsModal" class="fixed inset-0 bg-slate-900/40 hidden items-center justify-center z-[60] p-4 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl my-auto transform transition-all flex flex-col max-h-[90vh]">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-white rounded-t-2xl shrink-0">
                <div>
                    <h3 class="text-xl font-bold text-slate-800">Variantes y Opciones</h3>
                    <p class="text-sm text-slate-500 font-medium mt-0.5" id="variantsItemName">Cargando...</p>
                </div>
                <button onclick="closeVariantsModal()" class="text-slate-400 hover:text-slate-600 bg-slate-50 hover:bg-slate-100 w-8 h-8 rounded-full flex items-center justify-center transition shrink-0">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto flex-grow bg-slate-50">
                <input type="hidden" id="varCatId">
                <input type="hidden" id="varItemId">

                <div id="variantsList" class="space-y-5">
                    <!-- Contenido dinámico -->
                </div>

                <div class="mt-6 border-2 border-dashed border-indigo-200 bg-indigo-50/30 rounded-xl p-4 text-center hover:bg-indigo-50 transition cursor-pointer group" onclick="addNewVariantGroup()">
                    <button class="text-indigo-600 font-medium flex items-center justify-center mx-auto group-hover:scale-105 transition-transform">
                        <i class="fas fa-plus-circle mr-2 text-lg"></i> Añadir Nuevo Grupo (Ej: Tamaños, Extras)
                    </button>
                </div>
            </div>

            <div class="px-6 py-4 bg-white border-t border-slate-100 rounded-b-2xl flex justify-between items-center shrink-0">
                <span class="text-xs text-slate-400 hidden sm:block"><i class="fas fa-info-circle mr-1"></i> Aplica al guardar</span>
                <div class="flex gap-3 w-full sm:w-auto justify-end">
                    <button onclick="closeVariantsModal()" class="px-5 py-2.5 bg-white border border-slate-200 rounded-xl text-slate-700 hover:bg-slate-50 font-medium transition active:scale-95 flex-1 sm:flex-none">Cancelar</button>
                    <button onclick="saveVariants()" id="btnSaveVariants" class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 font-medium shadow-sm shadow-indigo-200 transition active:scale-95 flex-1 sm:flex-none flex items-center justify-center">
                        <i class="fas fa-save mr-2"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- Sidebar ---
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            sidebar.classList.toggle('-translate-x-full');
            overlay.classList.toggle('hidden');
        }

        // --- Tabs Logic ---
        let currentCategoryId = null;

        function selectCategory(id, element) {
            currentCategoryId = id;

            // Actualizar botones tabs
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            if(element) element.classList.add('active');

            // Ocultar todos los contenidos
            document.querySelectorAll('.category-content').forEach(content => {
                content.classList.add('hidden');
                content.classList.remove('block');
            });

            // Mostrar el activo
            const activeContent = document.getElementById(`cat-content-${id}`);
            if(activeContent) {
                activeContent.classList.remove('hidden');
                activeContent.classList.add('block');
            }

            // Mostrar/Configurar FAB
            const fab = document.getElementById('fabAddItem');
            if(id) {
                fab.classList.remove('hidden');
            } else {
                fab.classList.add('hidden');
            }
        }

        function openAddItemModalForCurrentTab() {
            if(currentCategoryId) {
                openAddItemModal(currentCategoryId);
            }
        }

        // Init tabs
        document.addEventListener('DOMContentLoaded', () => {
            const firstTab = document.querySelector('.tab-btn');
            if(firstTab) {
                firstTab.click();
            }
        });

        // --- Basic CRUD ---
        function addCategoryPrompt() {
            Swal.fire({
                title: 'Nueva Categoría',
                input: 'text',
                inputPlaceholder: 'Ej: Hamburguesas, Bebidas...',
                showCancelButton: true,
                confirmButtonText: 'Crear',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#4f46e5',
                customClass: { confirmButton: 'rounded-xl', cancelButton: 'rounded-xl' },
                inputValidator: (value) => {
                    if (!value || value.trim() === '') return 'El nombre no puede estar vacío'
                }
            }).then((result) => {
                if (result.isConfirmed) addCategory(result.value.trim());
            });
        }

        async function addCategory(name) {
            try {
                const res = await fetch('/menu/category', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ category: name })
                });
                if(res.ok) window.location.reload();
                else Swal.fire('Error', 'No se pudo crear', 'error');
            } catch (e) { Swal.fire('Error', 'Problema de conexión', 'error'); }
        }

        function deleteCategory(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Se eliminarán todos los productos. No se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar',
                customClass: { confirmButton: 'rounded-xl', cancelButton: 'rounded-xl' }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/menu/category/${id}`, { method: 'DELETE' });
                    if(res.ok) window.location.reload();
                }
            });
        }

        function deleteItem(catId, itemId) {
            Swal.fire({
                title: '¿Eliminar producto?',
                text: "Esta acción es irreversible.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar',
                customClass: { confirmButton: 'rounded-xl', cancelButton: 'rounded-xl' }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/menu/item/${catId}/${itemId}`, { method: 'DELETE' });
                    if(res.ok) window.location.reload();
                }
            });
        }

        // --- Modals (Item) ---
        function openAddItemModal(catId) {
            document.getElementById('modalTitle').innerText = 'Nuevo Producto';
            document.getElementById('modalCategoryId').value = catId;
            document.getElementById('modalItemId').value = '';
            document.getElementById('itemName').value = '';
            document.getElementById('itemDesc').value = '';
            document.getElementById('itemPrice').value = '';
            document.getElementById('itemImage').value = '';
            document.getElementById('addItemModal').classList.remove('hidden');
            document.getElementById('addItemModal').classList.add('flex');
        }

        function openEditItemModal(catId, itemId, name, desc, price, image) {
            document.getElementById('modalTitle').innerText = 'Editar Producto';
            document.getElementById('modalCategoryId').value = catId;
            document.getElementById('modalItemId').value = itemId;
            document.getElementById('itemName').value = name;
            document.getElementById('itemDesc').value = desc;
            document.getElementById('itemPrice').value = price;
            document.getElementById('itemImage').value = image || '';
            document.getElementById('addItemModal').classList.remove('hidden');
            document.getElementById('addItemModal').classList.add('flex');
        }

        function closeAddItemModal() {
            document.getElementById('addItemModal').classList.add('hidden');
            document.getElementById('addItemModal').classList.remove('flex');
        }

        async function submitItem() {
            const btn = document.getElementById('btnSubmitItem');
            const catId = document.getElementById('modalCategoryId').value;
            const itemId = document.getElementById('modalItemId').value;
            const name = document.getElementById('itemName').value.trim();
            const priceStr = document.getElementById('itemPrice').value;

            if(!name || priceStr === '') return Swal.fire('Atención', 'Nombre y Precio Base son obligatorios', 'warning');

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...';

            const item = { name, description: document.getElementById('itemDesc').value, basePrice: parseFloat(priceStr) || 0, image: document.getElementById('itemImage').value };
            let url = '/menu/item', method = 'POST';
            if (!itemId) item.variants = [];
            let body = { categoryId: catId, item };
            if (itemId) { method = 'PUT'; item.id = parseInt(itemId); body = { categoryId: catId, itemId, item }; }

            try {
                const res = await fetch(url, { method, headers: {'Content-Type': 'application/json'}, body: JSON.stringify(body) });
                if(res.ok) window.location.reload();
                else Swal.fire('Error', 'No se pudo guardar', 'error');
            } catch (e) { Swal.fire('Error', 'Problema de red', 'error'); }
            finally { btn.disabled = false; btn.innerHTML = 'Guardar Producto'; }
        }

        // --- Modals & Logic (Variants) ---
        let currentVariants = [];

        function openVariantsModal(catId, itemId, itemName, variantsJsonEnconded) {
            document.getElementById('varCatId').value = catId;
            document.getElementById('varItemId').value = itemId;
            document.getElementById('variantsItemName').innerText = itemName;
            try { currentVariants = JSON.parse(decodeURIComponent(variantsJsonEnconded)); }
            catch (e) { currentVariants = []; }
            renderVariants();
            document.getElementById('variantsModal').classList.remove('hidden');
            document.getElementById('variantsModal').classList.add('flex');
        }

        function closeVariantsModal() {
            document.getElementById('variantsModal').classList.add('hidden');
            document.getElementById('variantsModal').classList.remove('flex');
        }

        function renderVariants() {
            const list = document.getElementById('variantsList');
            list.innerHTML = '';

            if (currentVariants.length === 0) {
                list.innerHTML = `<div class="text-center py-6 text-slate-400"><i class="fas fa-sliders-h text-3xl mb-3 opacity-30"></i><p>Este producto no tiene variantes.</p></div>`;
                return;
            }

            currentVariants.forEach((variant, vIndex) => {
                const div = document.createElement('div');
                div.className = "bg-white p-5 rounded-xl shadow-sm border border-slate-200 relative";

                let optionsHtml = '';
                variant.options.forEach((opt, oIndex) => {
                    optionsHtml += `
                        <div class="flex items-center gap-2 mb-2 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100 group transition-all focus-within:bg-white focus-within:border-indigo-200 focus-within:ring-1 focus-within:ring-indigo-100">
                            <i class="fas ${variant.type === 'radio' ? 'fa-circle text-xs text-slate-300' : 'fa-square text-xs text-slate-300'}"></i>
                            <input type="text" value="${opt.label}" class="flex-1 bg-transparent border-none focus:ring-0 text-sm font-semibold text-slate-700 p-0" onchange="updateOptionLabel(${vIndex}, ${oIndex}, this.value)" placeholder="Opción">
                            <span class="text-slate-400 font-medium text-sm">$</span>
                            <input type="number" value="${opt.price}" class="w-20 bg-transparent border-none focus:ring-0 text-sm text-right font-medium text-emerald-600 p-0" onchange="updateOptionPrice(${vIndex}, ${oIndex}, this.value)" placeholder="0">
                            <button onclick="removeOption(${vIndex}, ${oIndex})" class="text-slate-300 hover:text-rose-500 p-1 opacity-0 group-hover:opacity-100 transition-opacity"><i class="fas fa-times"></i></button>
                        </div>
                    `;
                });

                div.innerHTML = `
                    <div class="absolute top-4 right-4">
                        <button onclick="removeVariantGroup(${vIndex})" class="text-slate-400 hover:text-rose-500 w-8 h-8 rounded-full hover:bg-rose-50 flex items-center justify-center transition" title="Eliminar Grupo"><i class="fas fa-trash-alt"></i></button>
                    </div>

                    <div class="mb-4 pr-10">
                        <input type="text" value="${variant.name}" class="text-lg font-bold text-slate-800 bg-transparent border-b border-transparent hover:border-slate-200 focus:border-indigo-500 focus:outline-none w-full transition pb-1" onchange="updateVariantName(${vIndex}, this.value)" placeholder="Nombre del Grupo (Ej: Tamaño)">
                    </div>

                    <div class="mb-5 inline-flex bg-slate-100 p-1 rounded-lg">
                        <label class="cursor-pointer px-4 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider transition ${variant.type === 'radio' ? 'bg-white shadow-sm text-indigo-600' : 'text-slate-500 hover:text-slate-700'}">
                            <input type="radio" name="type_${vIndex}" value="radio" class="hidden" ${variant.type === 'radio' ? 'checked' : ''} onchange="updateVariantType(${vIndex}, 'radio')">
                            Radio (Solo una)
                        </label>
                        <label class="cursor-pointer px-4 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider transition ${variant.type === 'checkbox' ? 'bg-white shadow-sm text-indigo-600' : 'text-slate-500 hover:text-slate-700'}">
                            <input type="radio" name="type_${vIndex}" value="checkbox" class="hidden" ${variant.type === 'checkbox' ? 'checked' : ''} onchange="updateVariantType(${vIndex}, 'checkbox')">
                            Checkbox (Múltiples)
                        </label>
                    </div>

                    <div class="space-y-1">
                        ${optionsHtml}
                    </div>

                    <button onclick="addOption(${vIndex})" class="mt-3 text-sm text-indigo-600 font-semibold flex items-center hover:bg-indigo-50 px-3 py-2 rounded-lg transition-colors w-full justify-center border border-dashed border-indigo-200">
                        <i class="fas fa-plus mr-2"></i> Añadir Opción
                    </button>
                `;
                list.appendChild(div);
            });
        }

        function addNewVariantGroup() { currentVariants.push({ type: 'radio', name: 'Nuevo Grupo', options: [{ label: 'Opción 1', price: 0 }] }); renderVariants(); }
        function removeVariantGroup(index) { currentVariants.splice(index, 1); renderVariants(); }
        function updateVariantName(index, val) { currentVariants[index].name = val; }
        function updateVariantType(index, val) { currentVariants[index].type = val; renderVariants(); }
        function addOption(vIndex) { currentVariants[vIndex].options.push({ label: '', price: 0 }); renderVariants(); }
        function removeOption(vIndex, oIndex) { currentVariants[vIndex].options.splice(oIndex, 1); renderVariants(); }
        function updateOptionLabel(vIndex, oIndex, val) { currentVariants[vIndex].options[oIndex].label = val; }
        function updateOptionPrice(vIndex, oIndex, val) { currentVariants[vIndex].options[oIndex].price = parseFloat(val) || 0; }

        async function saveVariants() {
            const btn = document.getElementById('btnSaveVariants');
            const catId = document.getElementById('varCatId').value;
            const itemId = document.getElementById('varItemId').value;

            for(let v of currentVariants) {
                if(!v.name.trim()) return Swal.fire('Aviso', 'Los grupos necesitan un nombre', 'warning');
                for(let o of v.options) if(!o.label.trim()) return Swal.fire('Aviso', 'Las opciones necesitan nombre', 'warning');
            }

            btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...';

            try {
                const res = await fetch('/menu/item/variants', { method: 'PUT', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ categoryId: catId, itemId, variants: currentVariants }) });
                if(res.ok) window.location.reload();
                else Swal.fire('Error', 'Error al guardar', 'error');
            } catch (e) { Swal.fire('Error', 'Fallo de red', 'error'); }
            finally { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save mr-2"></i> Guardar'; }
        }
    </script>
</body>
</html>