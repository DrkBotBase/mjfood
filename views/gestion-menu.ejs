<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Menú - <%= restaurante %></title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- SweetAlert2 para modales y notificaciones -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .touch-target { min-height: 44px; min-width: 44px; }
        .nav-link { display: flex; align-items: center; padding: 0.75rem 1rem; border-radius: 0.5rem; transition: background-color 0.2s; }
        .nav-link:hover { background-color: #f3f4f6; }
        .nav-link.active { background-color: #e0e7ff; color: #4338ca; font-weight: 600; }
        .variant-item { border-left: 4px solid #4f46e5; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">

    <!-- Top Navigation Bar -->
    <header class="bg-white shadow-md sticky top-0 z-40">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <div class="flex-shrink-0 flex items-center gap-2">
                    <span class="text-xl font-bold text-indigo-600">
                        <i class="fas fa-utensils mr-2"></i>MJFOOD Panel
                    </span>
                </div>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex space-x-2">
                    <a href="/admin/panel" class="nav-link text-gray-700">
                        <i class="fas fa-home mr-2"></i>Inicio
                    </a>
                    <a href="/admin/panel#pendientes" class="nav-link text-gray-700">
                        <i class="fas fa-receipt mr-2"></i>Pedidos
                    </a>
                    <a href="/menu/gestion" class="nav-link active">
                        <i class="fas fa-book-open mr-2"></i>Mi Menú
                    </a>
                    <a href="/admin/panel#seguridad" class="nav-link text-gray-700">
                        <i class="fas fa-cog mr-2"></i>Configuración
                    </a>
                    <a href="/admin/logout" class="nav-link text-red-600 hover:bg-red-50">
                        <i class="fas fa-sign-out-alt mr-2"></i>Cerrar Sesión
                    </a>
                </nav>

                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-button" class="touch-target text-gray-600 hover:text-gray-900 focus:outline-none flex items-center justify-center">
                        <i class="fas fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Mobile Nav Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <a href="/admin/panel" class="nav-link text-gray-700">
                    <i class="fas fa-home mr-2"></i>Inicio
                </a>
                <a href="/admin/panel#pendientes" class="nav-link text-gray-700">
                    <i class="fas fa-receipt mr-2"></i>Pedidos
                </a>
                <a href="/menu/gestion" class="nav-link active">
                    <i class="fas fa-book-open mr-2"></i>Mi Menú
                </a>
                <a href="/admin/panel#seguridad" class="nav-link text-gray-700">
                    <i class="fas fa-cog mr-2"></i>Configuración
                </a>
                <a href="/admin/logout" class="nav-link text-red-600">
                    <i class="fas fa-sign-out-alt mr-2"></i>Cerrar Sesión
                </a>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8 max-w-5xl">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Menú de <%= menuData.config.nombre || restaurante %></h1>
                <p class="text-gray-500">Administra tus categorías, productos y variantes.</p>
            </div>
            <button onclick="addCategoryPrompt()" class="touch-target bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg shadow font-medium flex items-center transition">
                <i class="fas fa-folder-plus mr-2"></i> Nueva Categoría
            </button>
        </div>

        <div id="categoriesContainer" class="space-y-8">
            <% if(menuData && menuData.menu && menuData.menu.length > 0) { %>
                <% menuData.menu.forEach((cat) => { %>
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" id="cat-card-<%= cat._id %>">
                        <!-- Header de Categoría -->
                        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                            <h2 class="text-2xl font-bold text-gray-800 flex items-center">
                                <i class="fas fa-tag text-indigo-500 mr-3"></i><%= cat.category %>
                            </h2>
                            <div class="flex gap-2 w-full sm:w-auto">
                                <button onclick="openAddItemModal('<%= cat._id %>')" class="touch-target flex-1 sm:flex-none bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center justify-center transition">
                                    <i class="fas fa-plus mr-2"></i> Producto
                                </button>
                                <button onclick="deleteCategory('<%= cat._id %>')" class="touch-target bg-red-100 hover:bg-red-200 text-red-600 px-4 py-2 rounded-lg text-sm font-medium flex items-center justify-center transition">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Lista de Productos (Tarjetas Responsivas) -->
                        <div class="p-4 sm:p-6 bg-white">
                            <% if (cat.items && cat.items.length > 0) { %>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="cat-items-<%= cat._id %>">
                                    <% cat.items.forEach((item) => { %>
                                        <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition flex flex-col h-full relative group">

                                            <div class="flex items-start gap-4 mb-4">
                                                <% if(item.image) { %>
                                                    <img src="<%= item.image %>" class="w-20 h-20 object-cover rounded-lg border flex-shrink-0 shadow-sm">
                                                <% } else { %>
                                                    <div class="w-20 h-20 bg-gray-100 border rounded-lg flex items-center justify-center text-gray-400 flex-shrink-0">
                                                        <i class="fas fa-image text-2xl"></i>
                                                    </div>
                                                <% } %>
                                                <div class="flex-grow min-w-0">
                                                    <h3 class="font-bold text-lg text-gray-800 truncate" title="<%= item.name %>"><%= item.name %></h3>
                                                    <p class="text-sm text-gray-500 line-clamp-2 mt-1" title="<%= item.description %>"><%= item.description || 'Sin descripción' %></p>
                                                    <p class="text-green-600 font-bold text-lg mt-2">$<%= item.basePrice.toLocaleString('es-CO') %></p>
                                                </div>
                                            </div>

                                            <div class="mt-auto pt-3 border-t border-gray-100 flex flex-wrap gap-2 justify-between items-center">
                                                <button onclick="openVariantsModal('<%= cat._id %>', '<%= item.id %>', '<%= encodeURIComponent(JSON.stringify(item.variants || [])) %>')"
                                                        class="touch-target text-indigo-600 hover:bg-indigo-50 px-3 py-2 rounded-md text-sm font-medium flex items-center border border-indigo-200 transition">
                                                    <i class="fas fa-sliders-h mr-2"></i> Variantes (<%= (item.variants || []).length %>)
                                                </button>

                                                <div class="flex gap-2">
                                                    <button onclick="openEditItemModal('<%= cat._id %>', '<%= item.id %>', '<%= item.name.replace(/'/g, "\\'") %>', '<%= (item.description || '').replace(/'/g, "\\'") %>', <%= item.basePrice %>, '<%= item.image || '' %>')"
                                                            class="touch-target text-gray-600 hover:bg-gray-100 px-3 py-2 rounded-md transition" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <button onclick="deleteItem('<%= cat._id %>', '<%= item.id %>')"
                                                            class="touch-target text-red-500 hover:bg-red-50 px-3 py-2 rounded-md transition" title="Eliminar">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-8 text-gray-400 bg-gray-50 rounded-lg border border-dashed border-gray-200">
                                    <i class="fas fa-box-open text-4xl mb-3"></i>
                                    <p>Esta categoría está vacía. Añade tu primer producto.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center py-16 bg-white rounded-xl shadow-sm border border-gray-200">
                    <div class="bg-indigo-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-folder-open text-indigo-500 text-3xl"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-gray-700 mb-2">Tu menú está vacío</h2>
                    <p class="text-gray-500 mb-6 max-w-md mx-auto">Comienza creando una categoría para organizar tus productos (ej: Hamburguesas, Bebidas, Postres).</p>
                    <button onclick="addCategoryPrompt()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg shadow-md font-medium inline-flex items-center transition">
                        <i class="fas fa-plus mr-2"></i> Crear Primera Categoría
                    </button>
                </div>
            <% } %>
        </div>
    </main>

    <!-- Modal para añadir/editar producto -->
    <div id="addItemModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-md my-8 transform transition-all">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-800" id="modalTitle">Añadir Producto</h3>
                <button onclick="closeAddItemModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <div class="p-6 space-y-4">
                <input type="hidden" id="modalCategoryId">
                <input type="hidden" id="modalItemId">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre *</label>
                    <input type="text" id="itemName" placeholder="Ej: Hamburguesa Clásica" class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                    <textarea id="itemDesc" placeholder="Ingredientes y detalles..." rows="3" class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Precio Base ($) *</label>
                        <input type="number" id="itemPrice" placeholder="0" min="0" class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">URL de Imagen</label>
                    <input type="url" id="itemImage" placeholder="https://..." class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
            </div>

            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-xl flex justify-end gap-3">
                <button onclick="closeAddItemModal()" class="touch-target px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition">Cancelar</button>
                <button onclick="submitItem()" id="btnSubmitItem" class="touch-target px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium shadow-sm transition flex items-center">Guardar</button>
            </div>
        </div>
    </div>

    <!-- Modal para Variantes -->
    <div id="variantsModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden items-center justify-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl my-8 transform transition-all flex flex-col max-h-[90vh]">
            <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-gray-50 rounded-t-xl">
                <div>
                    <h3 class="text-xl font-bold text-gray-800">Gestionar Variantes</h3>
                    <p class="text-sm text-gray-500" id="variantsItemName">Cargando...</p>
                </div>
                <button onclick="closeVariantsModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto flex-grow bg-gray-50/50">
                <input type="hidden" id="varCatId">
                <input type="hidden" id="varItemId">

                <div id="variantsList" class="space-y-6">
                    <!-- Contenido dinámico de variantes -->
                </div>

                <div class="mt-6 border-2 border-dashed border-indigo-200 rounded-xl p-4 text-center hover:bg-indigo-50/50 transition cursor-pointer" onclick="addNewVariantGroup()">
                    <button class="text-indigo-600 font-medium flex items-center justify-center mx-auto">
                        <i class="fas fa-plus-circle mr-2 text-lg"></i> Añadir Nuevo Grupo de Variantes (Ej: Tamaños, Extras)
                    </button>
                </div>
            </div>

            <div class="px-6 py-4 bg-white border-t border-gray-200 rounded-b-xl flex justify-between items-center">
                <span class="text-sm text-gray-500 hidden sm:inline"><i class="fas fa-info-circle mr-1"></i> Los cambios aplican de inmediato al guardar.</span>
                <div class="flex gap-3 w-full sm:w-auto justify-end">
                    <button onclick="closeVariantsModal()" class="touch-target px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium transition flex-1 sm:flex-none">Cancelar</button>
                    <button onclick="saveVariants()" id="btnSaveVariants" class="touch-target px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium shadow-sm transition flex-1 sm:flex-none flex items-center justify-center">
                        <i class="fas fa-save mr-2"></i> Guardar Variantes
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- UI Interactions ---
        document.getElementById('mobile-menu-button').addEventListener('click', () => {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });

        // --- SweetAlert Prompts & Actions ---
        function addCategoryPrompt() {
            Swal.fire({
                title: 'Nueva Categoría',
                input: 'text',
                inputPlaceholder: 'Ej: Hamburguesas, Bebidas...',
                showCancelButton: true,
                confirmButtonText: 'Crear',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#4f46e5',
                inputValidator: (value) => {
                    if (!value || value.trim() === '') {
                        return 'El nombre no puede estar vacío'
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    addCategory(result.value.trim());
                }
            });
        }

        async function addCategory(name) {
            try {
                const res = await fetch('/menu/category', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ category: name })
                });
                if(res.ok) {
                    window.location.reload(); // Para categorías recargamos por simplicidad estructural
                } else {
                    Swal.fire('Error', 'No se pudo crear la categoría', 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'Problema de conexión', 'error');
            }
        }

        function deleteCategory(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Se eliminarán todos los productos de esta categoría. ¡Esta acción no se puede deshacer!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/menu/category/${id}`, { method: 'DELETE' });
                    if(res.ok) {
                        document.getElementById(`cat-card-${id}`).remove();
                        Swal.fire({title:'Eliminada', icon:'success', toast:true, position:'top-end', showConfirmButton:false, timer:2000});
                    }
                }
            });
        }

        function deleteItem(catId, itemId) {
            Swal.fire({
                title: '¿Eliminar producto?',
                text: "No podrás revertir esto.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Eliminar'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const res = await fetch(`/menu/item/${catId}/${itemId}`, { method: 'DELETE' });
                    if(res.ok) {
                        window.location.reload();
                    }
                }
            });
        }

        // --- Modals (Item) ---
        function openAddItemModal(catId) {
            document.getElementById('modalTitle').innerText = 'Nuevo Producto';
            document.getElementById('modalCategoryId').value = catId;
            document.getElementById('modalItemId').value = '';

            document.getElementById('itemName').value = '';
            document.getElementById('itemDesc').value = '';
            document.getElementById('itemPrice').value = '';
            document.getElementById('itemImage').value = '';

            document.getElementById('addItemModal').classList.remove('hidden');
            document.getElementById('addItemModal').classList.add('flex');
        }

        function openEditItemModal(catId, itemId, name, desc, price, image) {
            document.getElementById('modalTitle').innerText = 'Editar Producto';
            document.getElementById('modalCategoryId').value = catId;
            document.getElementById('modalItemId').value = itemId;

            document.getElementById('itemName').value = name;
            document.getElementById('itemDesc').value = desc;
            document.getElementById('itemPrice').value = price;
            document.getElementById('itemImage').value = image || '';

            document.getElementById('addItemModal').classList.remove('hidden');
            document.getElementById('addItemModal').classList.add('flex');
        }

        function closeAddItemModal() {
            document.getElementById('addItemModal').classList.add('hidden');
            document.getElementById('addItemModal').classList.remove('flex');
        }

        async function submitItem() {
            const btn = document.getElementById('btnSubmitItem');
            const catId = document.getElementById('modalCategoryId').value;
            const itemId = document.getElementById('modalItemId').value;
            const name = document.getElementById('itemName').value.trim();
            const priceStr = document.getElementById('itemPrice').value;

            if(!name || priceStr === '') {
                Swal.fire('Atención', 'Nombre y Precio Base son obligatorios', 'warning');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...';

            const item = {
                name: name,
                description: document.getElementById('itemDesc').value,
                basePrice: parseFloat(priceStr) || 0,
                image: document.getElementById('itemImage').value
            };

            let url = '/menu/item';
            let method = 'POST';

            if (!itemId) item.variants = [];

            let body = { categoryId: catId, item };
            if (itemId) {
                method = 'PUT';
                item.id = parseInt(itemId);
                body = { categoryId: catId, itemId: itemId, item };
            }

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(body)
                });

                if(res.ok) {
                    window.location.reload();
                } else {
                    Swal.fire('Error', 'No se pudo guardar el producto', 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'Problema de red', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Guardar';
            }
        }

        // --- Modals & Logic (Variants) ---
        let currentVariants = [];

        function openVariantsModal(catId, itemId, itemName, variantsJsonEnconded) {
            document.getElementById('varCatId').value = catId;
            document.getElementById('varItemId').value = itemId;
            document.getElementById('variantsItemName').innerText = itemName;

            try {
                currentVariants = JSON.parse(decodeURIComponent(variantsJsonEnconded));
            } catch (e) {
                currentVariants = [];
            }

            renderVariants();

            document.getElementById('variantsModal').classList.remove('hidden');
            document.getElementById('variantsModal').classList.add('flex');
        }

        function closeVariantsModal() {
            document.getElementById('variantsModal').classList.add('hidden');
            document.getElementById('variantsModal').classList.remove('flex');
        }

        function renderVariants() {
            const list = document.getElementById('variantsList');
            list.innerHTML = '';

            if (currentVariants.length === 0) {
                list.innerHTML = `<div class="text-center py-6 text-gray-500"><i class="fas fa-ghost text-2xl mb-2"></i><p>No hay variantes para este producto.</p></div>`;
                return;
            }

            currentVariants.forEach((variant, vIndex) => {
                const div = document.createElement('div');
                div.className = "bg-white p-5 rounded-xl border border-gray-200 shadow-sm variant-item relative";

                let optionsHtml = '';
                variant.options.forEach((opt, oIndex) => {
                    optionsHtml += `
                        <div class="flex items-center gap-2 mb-2 bg-gray-50 p-2 rounded-lg border border-gray-100">
                            <i class="fas ${variant.type === 'radio' ? 'fa-dot-circle' : 'fa-check-square'} text-gray-400"></i>
                            <input type="text" value="${opt.label}" class="flex-1 border-none bg-transparent focus:ring-0 text-sm font-medium p-1" onchange="updateOptionLabel(${vIndex}, ${oIndex}, this.value)" placeholder="Nombre opción">
                            <span class="text-gray-500 text-sm font-bold">$</span>
                            <input type="number" value="${opt.price}" class="w-20 border-b border-gray-300 bg-transparent focus:border-indigo-500 focus:ring-0 text-sm text-right p-1" onchange="updateOptionPrice(${vIndex}, ${oIndex}, this.value)" placeholder="0">
                            <button onclick="removeOption(${vIndex}, ${oIndex})" class="text-red-400 hover:text-red-600 px-2 py-1"><i class="fas fa-times"></i></button>
                        </div>
                    `;
                });

                div.innerHTML = `
                    <div class="absolute top-4 right-4 flex gap-2">
                        <button onclick="removeVariantGroup(${vIndex})" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition" title="Eliminar Grupo"><i class="fas fa-trash-alt"></i></button>
                    </div>

                    <div class="mb-4 pr-12">
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Nombre del Grupo</label>
                        <input type="text" value="${variant.name}" class="text-lg font-bold border-b-2 border-transparent hover:border-gray-200 focus:border-indigo-500 focus:outline-none bg-transparent w-full transition" onchange="updateVariantName(${vIndex}, this.value)" placeholder="Ej: Tamaño, Extras">
                    </div>

                    <div class="mb-4 bg-gray-50 inline-block p-1 rounded-lg border border-gray-200">
                        <label class="cursor-pointer px-3 py-1.5 rounded-md text-sm font-medium transition ${variant.type === 'radio' ? 'bg-white shadow-sm text-indigo-700' : 'text-gray-500 hover:text-gray-700'}">
                            <input type="radio" name="type_${vIndex}" value="radio" class="hidden" ${variant.type === 'radio' ? 'checked' : ''} onchange="updateVariantType(${vIndex}, 'radio')">
                            Selección Única (Radio)
                        </label>
                        <label class="cursor-pointer px-3 py-1.5 rounded-md text-sm font-medium transition ${variant.type === 'checkbox' ? 'bg-white shadow-sm text-indigo-700' : 'text-gray-500 hover:text-gray-700'}">
                            <input type="radio" name="type_${vIndex}" value="checkbox" class="hidden" ${variant.type === 'checkbox' ? 'checked' : ''} onchange="updateVariantType(${vIndex}, 'checkbox')">
                            Múltiple (Checkbox)
                        </label>
                    </div>

                    <div class="space-y-1 mt-2">
                        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Opciones Disponibles</h4>
                        ${optionsHtml}
                    </div>

                    <button onclick="addOption(${vIndex})" class="mt-3 text-sm text-indigo-600 hover:text-indigo-800 font-medium flex items-center bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-lg transition">
                        <i class="fas fa-plus mr-1"></i> Añadir Opción
                    </button>
                `;
                list.appendChild(div);
            });
        }

        // --- Variantes Data Handlers ---
        function addNewVariantGroup() {
            currentVariants.push({
                type: 'radio',
                name: 'Nuevo Grupo',
                options: [{ label: 'Opción 1', price: 0 }]
            });
            renderVariants();
        }
        function removeVariantGroup(index) {
            Swal.fire({
                title: '¿Eliminar este grupo de variantes?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Eliminar'
            }).then((result) => {
                if(result.isConfirmed) {
                    currentVariants.splice(index, 1);
                    renderVariants();
                }
            });
        }
        function updateVariantName(index, val) { currentVariants[index].name = val; }
        function updateVariantType(index, val) { currentVariants[index].type = val; renderVariants(); }
        function addOption(vIndex) {
            currentVariants[vIndex].options.push({ label: 'Nueva Opción', price: 0 });
            renderVariants();
        }
        function removeOption(vIndex, oIndex) {
            currentVariants[vIndex].options.splice(oIndex, 1);
            renderVariants();
        }
        function updateOptionLabel(vIndex, oIndex, val) { currentVariants[vIndex].options[oIndex].label = val; }
        function updateOptionPrice(vIndex, oIndex, val) { currentVariants[vIndex].options[oIndex].price = parseFloat(val) || 0; }

        async function saveVariants() {
            const btn = document.getElementById('btnSaveVariants');
            const catId = document.getElementById('varCatId').value;
            const itemId = document.getElementById('varItemId').value;

            // Basic validation
            for(let v of currentVariants) {
                if(!v.name.trim()) return Swal.fire('Error', 'Todos los grupos deben tener un nombre', 'warning');
                for(let o of v.options) {
                    if(!o.label.trim()) return Swal.fire('Error', 'Todas las opciones deben tener un nombre', 'warning');
                }
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Guardando...';

            try {
                const res = await fetch('/menu/item/variants', {
                    method: 'PUT',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ categoryId: catId, itemId: itemId, variants: currentVariants })
                });

                if(res.ok) {
                    window.location.reload(); // Recargamos para refrescar el JSON en los botones
                } else {
                    Swal.fire('Error', 'No se pudieron guardar las variantes', 'error');
                }
            } catch (e) {
                Swal.fire('Error', 'Problema de red', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-save mr-2"></i> Guardar Variantes';
            }
        }
    </script>
</body>
</html>